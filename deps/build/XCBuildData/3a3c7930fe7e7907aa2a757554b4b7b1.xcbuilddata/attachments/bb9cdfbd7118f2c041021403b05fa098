#!/bin/sh
python3 - "${SRCROOT}/app/Icons/Icons.plist" "${BUILT_PRODUCTS_DIR}/infoplisticons.h" <<END
import plistlib
import sys
print(sys.argv)
with open(sys.argv[1], 'rb') as plist:
    icons = plistlib.load(plist)
alt_icons = '<key>CFBundleAlternateIcons</key><dict>'
for icon in icons.keys():
    if icon == '': continue
    alt_icons += '''<key>{0}</key>
<dict>
<key>CFBundleIconFiles</key>
<array><string>{0}</string></array>
</dict>'''.format(icon)
alt_icons += '</dict>'
icon_stuff = '''</string>
<key>CFBundleIcons</key><dict>{0}</dict>
<key>CFBundleIcons~ipad</key><dict>{0}</dict>
<key>kxcode</key><string>'''.format(alt_icons)
icon_define = '#define ICON_STUFF ' + icon_stuff.replace('\n', '')
with open(sys.argv[2], 'w') as output:
    output.write(icon_define)
END
touch "${SRCROOT}/app/Info.plist"

